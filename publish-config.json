{
  "targets": {
    "grok": {
      "mode": "command",
      "command": [
        "/usr/local/bin/publish-grok-skill-family",
        "{bundle_dir}",
        "{family_name}"
      ]
    },
    "grok-build": {
      "mode": "command",
      "command": [
        "/usr/local/bin/publish-grok-build-skill-family",
        "{bundle_dir}",
        "{family_name}"
      ]
    },
    "claude": {
      "mode": "claude-skills"
    },
    "claude-code": {
      "mode": "claude-skills"
    },
    "chatgpt-work": {
      "mode": "manual"
    },
    "openai-skills-api": {
      "mode": "openai-skills",
      "api_key_env": "OPENAI_API_KEY"
    },
    "codex": {
      "mode": "codex-skills"
    }
  }
}
