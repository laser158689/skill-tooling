#!/bin/bash
set -euo pipefail

# create-family
# Scaffold a new skill family with proper structure + local git repo

if [[ $# -lt 2 ]]; then
  echo "Usage: create-family <family-name> \"Short description\""
  echo ""
  echo "Example:"
  echo "  create-family my-coaching-family \"Coordinated coaching staff for a specific sport\""
  exit 1
fi

FAMILY_NAME="$1"
DESCRIPTION="$2"
SKILL_DIR="/home/workdir/.grok/skills/$FAMILY_NAME"

if [[ -d "$SKILL_DIR" ]]; then
  echo "Error: Skill family '$FAMILY_NAME' already exists at $SKILL_DIR"
  exit 1
fi

echo "Creating new skill family: $FAMILY_NAME"
mkdir -p "$SKILL_DIR"

# Create SKILL.md
cat > "$SKILL_DIR/SKILL.md" << EOF
---
name: $FAMILY_NAME
description: $DESCRIPTION
---

# ${FAMILY_NAME^} Family

## Role
[Describe the overall purpose of this skill family. What problem does it solve?]

## Skills in this family
- \`$FAMILY_NAME-orchestrator\` (recommended) — main entry point
- Other specialist skills as needed

## How to use
Trigger this family by addressing the main skill or any specialists directly.

## Next steps after creation
1. Edit this \`SKILL.md\`
2. Add specialist skills if needed
3. Initialize GitHub repo and push (see guidance below)
EOF

# Create a basic README.md
cat > "$SKILL_DIR/README.md" << EOF
# $FAMILY_NAME

**Master repository for the $FAMILY_NAME skill family.**

This repo contains the canonical .md versions of the skills.

## Structure
- SKILL.md files for each skill in the family
- This README

## Deployment
Use the following command to deploy this family:

\`\`\`bash
bash /home/workdir/.grok/skills/skill-tooling/scripts/skill-deploy --repo YOUR_USERNAME/$FAMILY_NAME
\`\`\`
EOF

echo "\u2705 Created skill family at: $SKILL_DIR"

# Initialize local git repo
cd "$SKILL_DIR"
git init -q
git add .
git commit -q -m "Initial scaffold of $FAMILY_NAME family"
echo "\u2705 Initialized local git repository"

echo ""
echo "Next steps:"
echo "1. Edit $SKILL_DIR/SKILL.md with the real content"
echo "2. Create a new GitHub repository named '$FAMILY_NAME'"
echo "3. Push this local repo to GitHub:"
echo "   git remote add origin https://github.com/YOUR_USERNAME/$FAMILY_NAME.git"
echo "   git branch -M main"
echo "   git push -u origin main"
echo ""
echo "4. Once on GitHub, deploy with:"
echo "   bash /home/workdir/.grok/skills/skill-tooling/scripts/skill-deploy --repo YOUR_USERNAME/$FAMILY_NAME"
echo ""
echo "Done."